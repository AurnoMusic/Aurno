+'    <p style="font-family:Montserrat,\'Helvetica Neue\',Arial,sans-serif;font-size:10px;font-weight:500;color:#8A9BAB;letter-spacing:1.5px;text-transform:uppercase;margin:0 0 13px 0;">'+t+'</p>\n'
+'    <div style="width:26px;height:2px;background:#3A7FA8;margin-bottom:14px;"></div>\n'
+'    <table cellpadding="0" cellspacing="0">\n'
+'      <tr><td style="padding:3px 0;"><table cellpadding="0" cellspacing="0"><tr><td style="padding-right:8px;vertical-align:middle;font-size:13px;color:#3A7FA8;">&#9993;</td><td><a href="mailto:'+e+'" style="font-family:Montserrat,\'Helvetica Neue\',Arial,sans-serif;font-size:12px;color:#3A7FA8;text-decoration:none;font-weight:300;">'+e+'</a></td></tr></table></td></tr>\n'
