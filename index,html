<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AURNO · Email Signature Generator</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;500;700&family=DM+Mono:wght@300&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
<style>
:root {
  --obsidian: #0A0C0E;
  --deep-slate: #151C22;
  --teal: #3A7FA8;
  --teal-light: #5BA3CC;
  --slate-mist: #8A9BAB;
  --white: #FFFFFF;
  --border: rgba(58,127,168,0.18);
  --card-bg: #111518;
  --input-bg: #0F1418;
  --font-display: 'Montserrat', 'Helvetica Neue', Arial, sans-serif;
  --font-body: 'Montserrat', 'Helvetica Neue', Arial, sans-serif;
  --font-mono: 'DM Mono', 'Courier New', Courier, monospace;
}
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html, body {
  width: 100%; min-height: 100vh;
  background: var(--obsidian);
  color: var(--white);
  font-family: var(--font-body);
  font-weight: 300;
  font-size: 14px; line-height: 1.5;
}
body::before {
  content: ''; position: fixed; inset: 0;
  background-image:
    linear-gradient(rgba(58,127,168,0.05) 1px, transparent 1px),
    linear-gradient(90deg, rgba(58,127,168,0.05) 1px, transparent 1px);
  background-size: 48px 48px;
  pointer-events: none; z-index: 0;
}
.page { position: relative; z-index: 1; max-width: 1060px; margin: 0 auto; padding: 0 24px 60px; }

/* Header */
header {
  display: flex; align-items: center; justify-content: space-between;
  padding: 36px 0 24px; border-bottom: 1px solid var(--border);
  margin-bottom: 36px; flex-wrap: wrap; gap: 12px;
}
.header-logo { height: 38px; width: auto; }
.header-meta { text-align: right; }
.header-tag { font-family: var(--font-mono); font-size: 9px; color: var(--teal); letter-spacing: 2px; text-transform: uppercase; margin-bottom: 3px; }
.header-sub { font-size: 11px; color: var(--slate-mist); font-weight: 300; }

/* Grid */
.grid { display: grid; grid-template-columns: 380px 1fr; gap: 28px; align-items: start; }
@media (max-width: 780px) {
  .grid { grid-template-columns: 1fr; }
  header { flex-direction: column; align-items: flex-start; }
  .header-meta { text-align: left; }
}

/* Panel */
.panel { background: var(--card-bg); border: 1px solid var(--border); border-radius: 14px; padding: 24px; }
.panel-label { font-family: var(--font-mono); font-size: 9px; color: var(--teal); letter-spacing: 2.5px; text-transform: uppercase; margin-bottom: 20px; }
.field { margin-bottom: 14px; }
label { display: block; font-family: var(--font-display); font-size: 10px; font-weight: 500; color: var(--slate-mist); letter-spacing: 1.2px; text-transform: uppercase; margin-bottom: 5px; }
input[type="text"] {
  width: 100%; background: var(--input-bg);
  border: 1px solid rgba(58,127,168,0.22); border-radius: 7px;
  padding: 9px 12px; font-family: var(--font-body); font-size: 13px; font-weight: 300;
  color: var(--white); outline: none;
  transition: border-color 0.18s, box-shadow 0.18s;
}
input[type="text"]:focus { border-color: var(--teal); box-shadow: 0 0 0 3px rgba(58,127,168,0.13); }
input[type="text"]::placeholder { color: rgba(138,155,171,0.38); }
.rule { height: 1px; background: var(--border); margin: 18px 0; }

/* Style toggle */
.toggle-row { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin-bottom: 18px; }
.tog {
  padding: 9px 0; border-radius: 7px;
  border: 1px solid rgba(58,127,168,0.25);
  background: transparent; color: var(--slate-mist);
  font-family: var(--font-display); font-size: 12px; font-weight: 500;
  cursor: pointer; letter-spacing: 0.5px; text-align: center; transition: all 0.18s;
}
.tog.on { background: rgba(58,127,168,0.16); border-color: var(--teal); color: var(--teal-light); }
.tog:hover:not(.on) { border-color: rgba(58,127,168,0.5); color: var(--white); }

/* Action buttons */
.btn-group { display: flex; flex-direction: column; gap: 10px; margin-top: 4px; }

.copy-btn {
  width: 100%; padding: 13px;
  border: none; border-radius: 9px;
  color: var(--white); font-family: var(--font-display);
  font-size: 12px; font-weight: 700; letter-spacing: 1.2px;
  text-transform: uppercase; cursor: pointer;
  transition: background 0.18s, transform 0.1s;
}
.copy-btn:active { transform: scale(0.98); }

.btn-html { background: var(--teal); }
.btn-html:hover { background: #2d6a8f; }
.btn-html.ok { background: #1a6640; }

.btn-img { background: transparent; border: 1px solid rgba(58,127,168,0.4); color: var(--teal-light); }
.btn-img:hover { background: rgba(58,127,168,0.1); border-color: var(--teal); }
.btn-img.ok { background: #1a6640; border-color: #1a6640; color: #fff; }
.btn-img.loading { opacity: 0.6; cursor: wait; }

.btn-dl { background: transparent; border: 1px solid rgba(138,155,171,0.25); color: var(--slate-mist); font-size: 11px; padding: 10px; }
.btn-dl:hover { border-color: rgba(58,127,168,0.4); color: var(--teal-light); }

/* Section labels */
.section-label { font-family: var(--font-mono); font-size: 9px; color: var(--teal); letter-spacing: 2.5px; text-transform: uppercase; margin-bottom: 12px; }

/* Preview */
.preview-wrap {
  border-radius: 12px; overflow: hidden;
  border: 1px solid var(--border);
  background: #e8e8e8; padding: 28px; margin-bottom: 20px;
}

/* Tab bar */
.tabs { display: flex; gap: 0; margin-bottom: 16px; border: 1px solid var(--border); border-radius: 8px; overflow: hidden; }
.tab {
  flex: 1; padding: 9px 0; text-align: center;
  font-family: var(--font-display); font-size: 11px; font-weight: 700; letter-spacing: 0.8px;
  color: var(--slate-mist); background: var(--card-bg);
  border: none; cursor: pointer;
  transition: all 0.15s; text-transform: uppercase;
}
.tab.on { background: rgba(58,127,168,0.15); color: var(--teal-light); }
.tab:hover:not(.on) { color: var(--white); }
.tab:first-child { border-right: 1px solid var(--border); }

/* Code output */
.code-wrap { background: #070910; border: 1px solid var(--border); border-radius: 9px; padding: 14px; margin-bottom: 24px; }
.code-bar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px; }
.code-bar-label { font-family: var(--font-mono); font-size: 9px; color: var(--slate-mist); letter-spacing: 1.2px; }
.code-copy { font-family: var(--font-display); font-size: 10px; font-weight: 700; color: var(--teal-light); background: rgba(58,127,168,0.1); border: 1px solid rgba(58,127,168,0.25); border-radius: 5px; padding: 3px 9px; cursor: pointer; transition: background 0.15s; }
.code-copy:hover { background: rgba(58,127,168,0.2); }
pre { font-family: var(--font-mono); font-size: 10px; color: rgba(138,155,171,0.65); white-space: pre-wrap; word-break: break-all; max-height: 140px; overflow-y: auto; line-height: 1.6; }

/* Image panel */
.img-panel { display: none; margin-bottom: 24px; }
.img-panel.show { display: block; }
.img-preview-box {
  background: #e8e8e8; border-radius: 10px;
  padding: 24px; display: flex; justify-content: center;
  border: 1px solid var(--border); margin-bottom: 12px;
}
.img-preview-box img { max-width: 100%; display: block; }
.img-hint { font-family: var(--font-mono); font-size: 9px; color: var(--slate-mist); letter-spacing: 1px; text-align: center; line-height: 1.7; }
.img-actions { display: flex; gap: 8px; margin-top: 10px; }
.img-actions button {
  flex: 1; padding: 10px; border-radius: 7px;
  font-family: var(--font-display); font-size: 11px; font-weight: 700;
  letter-spacing: 0.8px; cursor: pointer; transition: all 0.15s;
  text-transform: uppercase;
}
.img-copy-btn { background: var(--teal); border: none; color: #fff; }
.img-copy-btn:hover { background: #2d6a8f; }
.img-copy-btn.ok { background: #1a6640; }
.img-dl-btn { background: transparent; border: 1px solid rgba(58,127,168,0.3); color: var(--teal-light); }
.img-dl-btn:hover { background: rgba(58,127,168,0.1); }

/* Signature styles */
.sig { font-family: 'Montserrat', 'Helvetica Neue', Arial, sans-serif; max-width: 460px; padding: 26px 30px; border-left: 3px solid #3A7FA8; font-weight: 300; }
.sig.dark { background: #0A0C0E; }
.sig.light { background: #ffffff; }
.sig-logo { display: block; height: 32px; width: auto; margin-bottom: 6px; }
.sig-tag { font-family: 'DM Mono', 'Courier New', monospace; font-size: 9px; color: #3A7FA8; letter-spacing: 1.4px; text-transform: uppercase; margin-bottom: 16px; font-weight: 300; }
.sig-name { font-family: 'Montserrat', 'Helvetica Neue', Arial, sans-serif; font-size: 16px; font-weight: 700; margin-bottom: 2px; }
.sig.dark .sig-name { color: #ffffff; }
.sig.light .sig-name { color: #0A0C0E; }
.sig-role { font-family: 'Montserrat', 'Helvetica Neue', Arial, sans-serif; font-size: 10px; font-weight: 500; color: #8A9BAB; letter-spacing: 1.5px; text-transform: uppercase; margin-bottom: 13px; }
.sig-bar { width: 26px; height: 2px; background: #3A7FA8; margin-bottom: 14px; }
.sig-row { display: flex; align-items: center; gap: 8px; margin-bottom: 5px; }
.sig-ico { width: 13px; height: 13px; flex-shrink: 0; }
.sig-val { font-family: 'Montserrat', 'Helvetica Neue', Arial, sans-serif; font-size: 11.5px; font-weight: 300; text-decoration: none; }
.sig.dark .sig-val { color: #8A9BAB; }
.sig.light .sig-val { color: #151C22; }
.sig-lnk { font-family: 'Montserrat', 'Helvetica Neue', Arial, sans-serif; font-size: 11.5px; font-weight: 300; color: #3A7FA8; text-decoration: none; }
.sig-lnk2 { color: #5BA3CC; }
.sig-foot { margin-top: 16px; padding-top: 13px; font-family: 'DM Mono', 'Courier New', monospace; font-size: 8.5px; letter-spacing: 0.8px; font-weight: 300; }
.sig.dark .sig-foot { border-top: 1px solid #151C22; color: #3A7FA8; }
.sig.light .sig-foot { border-top: 1px solid #e5e7eb; color: #8A9BAB; }

/* Instructions */
.how { background: var(--card-bg); border: 1px solid var(--border); border-radius: 14px; padding: 22px 24px; }
.how-title { font-family: var(--font-mono); font-size: 9px; color: var(--teal); letter-spacing: 2.5px; text-transform: uppercase; margin-bottom: 18px; }
.step { display: flex; gap: 13px; margin-bottom: 14px; align-items: flex-start; }
.step-n { width: 22px; height: 22px; border-radius: 50%; background: rgba(58,127,168,0.14); border: 1px solid rgba(58,127,168,0.3); color: var(--teal-light); font-family: var(--font-display); font-size: 10px; font-weight: 700; display: flex; align-items: center; justify-content: center; flex-shrink: 0; margin-top: 1px; }
.step-app { font-family: var(--font-display); font-size: 12px; font-weight: 700; color: var(--white); margin-bottom: 3px; }
.step-desc { font-size: 11.5px; color: var(--slate-mist); line-height: 1.65; font-weight: 300; }
.step-desc code { font-family: var(--font-mono); font-size: 10.5px; color: var(--teal-light); background: rgba(58,127,168,0.1); padding: 1px 5px; border-radius: 3px; }
.step-rule { height: 1px; background: var(--border); margin: 0 0 14px 35px; }

/* Badge */
.badge { display: inline-block; font-family: var(--font-mono); font-size: 8px; letter-spacing: 1px; padding: 2px 7px; border-radius: 4px; margin-left: 6px; vertical-align: middle; }
.badge-new { background: rgba(58,127,168,0.2); color: var(--teal-light); border: 1px solid rgba(58,127,168,0.3); }

/* Toast */
.toast { position: fixed; bottom: 28px; left: 50%; transform: translateX(-50%) translateY(16px); background: var(--teal); color: var(--white); padding: 11px 24px; border-radius: 100px; font-family: var(--font-display); font-size: 12px; font-weight: 700; letter-spacing: 0.5px; opacity: 0; transition: all 0.22s; pointer-events: none; z-index: 999; white-space: nowrap; }
.toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }

/* Hidden render target */
#sig-render-target { position: absolute; left: -9999px; top: 0; }

@keyframes up { from { opacity:0; transform:translateY(14px); } to { opacity:1; transform:none; } }
.panel { animation: up 0.45s ease both; }
.right { animation: up 0.45s 0.08s ease both; }
</style>
</head>
<body>

<div class="page">
  <header>
    <img class="header-logo" src="data:image/png;base64," alt="AURNO">
    <div class="header-meta">
      <div class="header-tag">Internal Tool · Marketing Dept</div>
      <div class="header-sub">Email Signature Generator · v2.1 · 2026</div>
    </div>
  </header>

  <div class="grid">
    <!-- LEFT -->
    <div class="panel">
      <div class="panel-label">Your Details</div>
      <div class="field"><label>Full Name</label><input type="text" id="f-name" value="Jane Doe" oninput="update()" placeholder="e.g. Jordan Lee"></div>
      <div class="field"><label>Job Title</label><input type="text" id="f-title" value="Founder &amp; CEO" oninput="update()" placeholder="e.g. Head of Growth"></div>
      <div class="field"><label>Email</label><input type="text" id="f-email" value="andrew@aurno.io" oninput="update()" placeholder="name@aurno.io"></div>
      <div class="field"><label>Phone</label><input type="text" id="f-phone" value="+1 (555) 000-0000" oninput="update()" placeholder="+1 (555) 000-0000"></div>
      <div class="field"><label>Website</label><input type="text" id="f-web" value="aurno.io" oninput="update()"></div>
      <div class="field"><label>Booking Link <span style="opacity:0.5;font-size:9px;">(optional)</span></label><input type="text" id="f-cal" value="cal.com/aurno" oninput="update()" placeholder="cal.com/yourname"></div>

      <div class="rule"></div>
      <div class="panel-label" style="margin-bottom:10px;">Signature Style</div>
      <div class="toggle-row">
        <button class="tog on" id="btn-dark" onclick="setStyle('dark')">Dark</button>
        <button class="tog" id="btn-light" onclick="setStyle('light')">Light</button>
      </div>

      <div class="rule"></div>
      <div class="panel-label" style="margin-bottom:14px;">Export Options</div>
      <div class="btn-group">
        <button class="copy-btn btn-html" id="main-copy" onclick="copyHTML()">Copy HTML Code</button>
        <button class="copy-btn btn-img" id="img-copy-btn" onclick="generateAndCopyImage()">Copy as Image <span class="badge badge-new">RECOMMENDED</span></button>
        <button class="copy-btn btn-dl" id="img-dl-btn" onclick="downloadImage()">Download as PNG</button>
      </div>
    </div>

    <!-- RIGHT -->
    <div class="right">
      <div class="section-label">Live Preview</div>
      <div class="preview-wrap">
        <div id="sig-preview"></div>
      </div>

      <!-- Output tabs -->
      <div class="tabs">
        <button class="tab on" id="tab-html" onclick="showTab('html')">HTML Code</button>
        <button class="tab" id="tab-img" onclick="showTab('img')">Image Preview</button>
      </div>

      <!-- HTML panel -->
      <div id="panel-html">
        <div class="code-wrap">
          <div class="code-bar">
            <span class="code-bar-label">HTML — PASTE INTO EMAIL CLIENT</span>
            <button class="code-copy" onclick="copyHTML()">Copy</button>
          </div>
          <pre id="code-out"></pre>
        </div>
      </div>

      <!-- Image panel -->
      <div id="panel-img" class="img-panel">
        <div class="img-preview-box">
          <img id="sig-img-preview" src="" alt="Signature image preview" style="display:none;">
          <div id="img-placeholder" style="font-family:var(--font-mono);font-size:10px;color:#555;letter-spacing:1px;">Click "Copy as Image" to generate</div>
        </div>
        <div class="img-hint">
          Right-click the image above to copy or save it<br>
          Or use the buttons below
        </div>
        <div class="img-actions">
          <button class="img-copy-btn" id="img-copy-btn2" onclick="copyImageFromPreview()">Copy Image</button>
          <button class="img-dl-btn" onclick="downloadImage()">Download PNG</button>
        </div>
      </div>

      <!-- Instructions -->
      <div class="how">
        <div class="how-title">How to Install Your Signature</div>

        <div class="step">
          <div class="step-n">1</div>
          <div>
            <div class="step-app">Outlook Web (Recommended — Image method)</div>
            <div class="step-desc">Click <code>Copy as Image</code>, then go to <code>Settings → Mail → Compose and reply → Signature</code>. Click in the signature box and paste with <code>Cmd+V</code>. Done.</div>
          </div>
        </div>
        <div class="step-rule"></div>

        <div class="step">
          <div class="step-n">2</div>
          <div>
            <div class="step-app">Apple Mail</div>
            <div class="step-desc">Click <code>Copy as Image</code>, go to <code>Mail → Settings → Signatures → +</code>, click in the signature area and paste with <code>Cmd+V</code>.</div>
          </div>
        </div>
        <div class="step-rule"></div>

        <div class="step">
          <div class="step-n">3</div>
          <div>
            <div class="step-app">Gmail</div>
            <div class="step-desc">Click <code>Copy as Image</code>, go to <code>Settings → See all settings → Signature</code>, click in the box and paste with <code>Cmd+V</code>.</div>
          </div>
        </div>
        <div class="step-rule"></div>

        <div class="step">
          <div class="step-n">4</div>
          <div>
            <div class="step-app">HTML method (advanced)</div>
            <div class="step-desc">Use <code>Copy HTML Code</code> for clients that support HTML source editing. Links will be clickable. The logo is embedded as base64 so the signature is self-contained — no broken images. The image method remains easier for most people.</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Hidden render target for html2canvas -->
<div id="sig-render-target"></div>

<div class="toast" id="toast"></div>

<script>
var LOGO_WHITE = 'data:image/png;base64,';
var LOGO_BLACK = 'data:image/png;base64,';
var style = 'dark';
var lastCanvas = null;

function g(id){ return document.getElementById(id).value.trim(); }

function setStyle(s){
  style = s;
  document.getElementById('btn-dark').className = 'tog' + (s==='dark'?' on':'');
  document.getElementById('btn-light').className = 'tog' + (s==='light'?' on':'');
  lastCanvas = null;
  update();
}

function showTab(t){
  document.getElementById('tab-html').className = 'tab' + (t==='html'?' on':'');
  document.getElementById('tab-img').className = 'tab' + (t==='img'?' on':'');
  document.getElementById('panel-html').style.display = t==='html' ? 'block' : 'none';
  document.getElementById('panel-img').className = 'img-panel' + (t==='img'?' show':'');
}

function esc(str){ return str.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }

function buildPreview(n,t,e,p,w,c,s){
  var cls = s==='dark' ? 'dark' : 'light';
  var logoSrc = s==='dark' ? LOGO_WHITE : LOGO_BLACK;
  var calRow = c ? '<div class="sig-row"><svg class="sig-ico" viewBox="0 0 16 16" fill="none"><rect x="2" y="3" width="12" height="11" rx="2" stroke="#5BA3CC" stroke-width="1.3"/><path d="M5 2v2M11 2v2M2 7h12" stroke="#5BA3CC" stroke-width="1.3" stroke-linecap="round"/></svg><a href="https://'+esc(c)+'" class="sig-lnk sig-lnk2">Book a call → '+esc(c)+'</a></div>' : '';
  return '<div class="sig '+cls+'">'
    +'<img class="sig-logo" src="'+logoSrc+'" alt="AURNO">'
    +'<div class="sig-tag">Music that moves with you</div>'
    +'<div class="sig-name">'+(n||'Your Name')+'</div>'
    +'<div class="sig-role">'+(t||'Your Title')+'</div>'
    +'<div class="sig-bar"></div>'
    +'<div class="sig-row"><svg class="sig-ico" viewBox="0 0 16 16" fill="none"><path d="M2 4l6 5 6-5M2 4h12v9H2z" stroke="#3A7FA8" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/></svg><a href="mailto:'+esc(e)+'" class="sig-lnk">'+esc(e||'email@aurno.io')+'</a></div>'
    +'<div class="sig-row"><svg class="sig-ico" viewBox="0 0 16 16" fill="none"><path d="M2 3.5C2 3.5 4 2 5 3.5L6.5 6C6.5 6 5 7 5.5 8.5C6 10 8 11.5 9.5 12C11 12.5 11.5 11 11.5 11L14 12.5C15.5 13.5 14 15.5 14 15.5C3 15.5 2 3.5 2 3.5Z" stroke="#3A7FA8" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/></svg><span class="sig-val">'+esc(p||'+1 (555) 000-0000')+'</span></div>'
    +'<div class="sig-row"><svg class="sig-ico" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="6" stroke="#3A7FA8" stroke-width="1.3"/><path d="M8 2c0 0-3 2-3 6s3 6 3 6M8 2c0 0 3 2 3 6s-3 6-3 6M2 8h12" stroke="#3A7FA8" stroke-width="1.3" stroke-linecap="round"/></svg><a href="https://'+esc(w)+'" class="sig-lnk">'+esc(w||'aurno.io')+'</a></div>'
    + calRow
    +'<div class="sig-foot">AURNO &middot; AURNO.IO &middot; CONFIDENTIAL</div>'
    +'</div>';
}

function buildExport(n,t,e,p,w,c,s){
  var isDark = s==='dark';
  var bg = isDark ? '#0A0C0E' : '#ffffff';
  var nameCol = isDark ? '#ffffff' : '#0A0C0E';
  var phoneCol = isDark ? '#8A9BAB' : '#151C22';
  var footBorder = isDark ? '#151C22' : '#e5e7eb';
  var footCol = isDark ? '#3A7FA8' : '#8A9BAB';
  var logoSrc = isDark ? LOGO_WHITE : LOGO_BLACK;
  var calRow = c ? '\n      <tr><td style="padding:3px 0;"><table cellpadding="0" cellspacing="0"><tr><td style="padding-right:8px;vertical-align:middle;font-size:13px;color:#5BA3CC;">&#128197;</td><td><a href="https://'+c+'" style="font-family:Montserrat,\'Helvetica Neue\',Arial,sans-serif;font-size:12px;color:#5BA3CC;text-decoration:none;">Book a call &rarr; '+c+'</a></td></tr></table></td></tr>' : '';
  return '<!-- AURNO Email Signature ('+(isDark?'Dark':'Light')+') · aurno.io -->\n'
+'<table cellpadding="0" cellspacing="0" border="0" style="background:'+bg+';border-left:3px solid #3A7FA8;padding:26px 30px;font-family:Montserrat,\'Helvetica Neue\',Arial,sans-serif;max-width:460px;">\n'
