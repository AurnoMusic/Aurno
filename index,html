+'      <tr><td style="padding:3px 0;"><table cellpadding="0" cellspacing="0"><tr><td style="padding-right:8px;vertical-align:middle;font-size:13px;color:#3A7FA8;">&#127760;</td><td><a href="https://'+w+'" style="font-family:Montserrat,\'Helvetica Neue\',Arial,sans-serif;font-size:12px;color:#3A7FA8;text-decoration:none;font-weight:300;">'+w+'</a></td></tr></table></td></tr>'
+ calRow +'\n'
