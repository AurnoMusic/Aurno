function update(){
  var n=g('f-name'), t=g('f-title'), e=g('f-email'), p=g('f-phone'), w=g('f-web'), c=g('f-cal');
  document.getElementById('sig-preview').innerHTML = buildPreview(n,t,e,p,w,c,style);
  document.getElementById('code-out').textContent = buildExport(n,t,e,p,w,c,style);
  document.getElementById('sig-render-target').innerHTML = buildPreview(n,t,e,p,w,c,style);
  lastCanvas = null;
}

function showToast(msg){
  var t = document.getElementById('toast');
  t.textContent = msg;
  t.className = 'toast show';
  setTimeout(function(){ t.className = 'toast'; }, 2800);
}

function copyHTML(){
  var n=g('f-name'), t=g('f-title'), e=g('f-email'), p=g('f-phone'), w=g('f-web'), c=g('f-cal');
  var html = buildExport(n,t,e,p,w,c,style);
  var btn = document.getElementById('main-copy');
  doClipboardText(html, function(){
    btn.textContent = 'Copied!'; btn.className='copy-btn btn-html ok';
    showToast('HTML copied to clipboard');
    setTimeout(function(){ btn.textContent='Copy HTML Code'; btn.className='copy-btn btn-html'; }, 2600);
  });
}

function doClipboardText(text, cb){
  if(navigator.clipboard && navigator.clipboard.writeText){
    navigator.clipboard.writeText(text).then(cb).catch(function(){ fallbackCopyText(text, cb); });
  } else { fallbackCopyText(text, cb); }
}

function fallbackCopyText(text, cb){
  var ta = document.createElement('textarea');
  ta.value = text; ta.style.position='fixed'; ta.style.opacity='0';
  document.body.appendChild(ta); ta.select();
  document.execCommand('copy'); document.body.removeChild(ta);
  cb();
}

function renderToCanvas(cb){
  if(lastCanvas){ cb(lastCanvas); return; }
  var target = document.getElementById('sig-render-target').firstElementChild;
  if(!target){ showToast('Please fill in your details first'); return; }
  // Give the logo image a moment to load if needed
  var logoImg = target.querySelector('img.sig-logo');
  var go = function(){
    html2canvas(target, {
      scale: 2,
      useCORS: true,
      backgroundColor: null,
      logging: false
    }).then(function(canvas){
      lastCanvas = canvas;
      cb(canvas);
    }).catch(function(err){
      showToast('Image generation failed — try the HTML method');
      console.error(err);
    });
  };
  if(logoImg && !logoImg.complete){ logoImg.onload = go; logoImg.onerror = go; }
  else { go(); }
}

function generateAndCopyImage(){
  var btn = document.getElementById('img-copy-btn');
  btn.textContent = 'Generating...'; btn.className='copy-btn btn-img loading';

  renderToCanvas(function(canvas){
    var imgEl = document.getElementById('sig-img-preview');
    var ph = document.getElementById('img-placeholder');
    imgEl.src = canvas.toDataURL('image/png');
    imgEl.style.display = 'block';
    ph.style.display = 'none';

    canvas.toBlob(function(blob){
      if(navigator.clipboard && navigator.clipboard.write && window.ClipboardItem){
        var item = new ClipboardItem({'image/png': blob});
        navigator.clipboard.write([item]).then(function(){
          btn.innerHTML = 'Image Copied!'; btn.className='copy-btn btn-img ok';
          showToast('Image copied — paste into your email client');
          setTimeout(function(){ btn.innerHTML='Copy as Image <span class="badge badge-new">RECOMMENDED</span>'; btn.className='copy-btn btn-img'; }, 3000);
        }).catch(function(){
          showTab('img');
          btn.innerHTML = 'Copy as Image <span class="badge badge-new">RECOMMENDED</span>'; btn.className='copy-btn btn-img';
          showToast('Right-click the image in the Image Preview tab to copy');
        });
      } else {
        showTab('img');
        btn.innerHTML = 'Copy as Image <span class="badge badge-new">RECOMMENDED</span>'; btn.className='copy-btn btn-img';
        showToast('Right-click the image in the Image Preview tab to copy');
      }
    }, 'image/png');
  });
}

function copyImageFromPreview(){
  var btn = document.getElementById('img-copy-btn2');
  if(!lastCanvas){ showToast('Generate the image first using "Copy as Image"'); return; }
  lastCanvas.toBlob(function(blob){
    if(navigator.clipboard && navigator.clipboard.write && window.ClipboardItem){
      var item = new ClipboardItem({'image/png': blob});
      navigator.clipboard.write([item]).then(function(){
        btn.textContent='Copied!'; btn.className='img-copy-btn ok';
        showToast('Image copied to clipboard');
        setTimeout(function(){ btn.textContent='Copy Image'; btn.className='img-copy-btn'; }, 2800);
      }).catch(function(){
        showToast('Right-click the image above to copy it');
      });
    } else {
      showToast('Right-click the image above to copy it');
    }
  }, 'image/png');
}

function downloadImage(){
  renderToCanvas(function(canvas){
    var a = document.createElement('a');
    var n = g('f-name').replace(/\s+/g,'-').toLowerCase() || 'aurno';
    a.download = 'aurno-signature-'+n+'.png';
    a.href = canvas.toDataURL('image/png');
    a.click();
    showToast('PNG downloaded');
  });
}

update();
</script>
